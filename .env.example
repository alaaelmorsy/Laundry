# Copy to .env and adjust. Used by `npm run web` (server/index.js).

PORT=3000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_PORT=3306
DB_NAME=laundry_db

# Optional: path to Chrome for PDF export (puppeteer-core). Default paths are tried on Windows/macOS/Linux.
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Required in production (min 16 characters)
# JWT_SECRET=change_this_to_a_long_random_string

# Langbly API key for auto-translation (Arabic → English) in services screen
# Get your free key at https://langbly.com/signup
# LANGBLY_API_KEY=your_langbly_api_key_here

# Encryption key for securing email app passwords (min 16 characters)
# EMAIL_SECRET_KEY=change_this_to_a_long_random_string
