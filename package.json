{
  "name": "laundry-app",
  "version": "1.0.3",
  "description": "Laundry Management System",
  "bin": "server/index.js",
  "pkg": {
    "targets": ["node18-win-x64"],
    "assets": [
      "screens/**/*",
      "assets/**/*",
      "node_modules/@whiskeysockets/baileys/WAProto/**"
    ],
    "outputPath": "dist"
  },
  "scripts": {
    "start": "node server/index.js",
    "web": "node server/index.js",
    "build": "pkg . --compress GZip --icon assets\\icon\\app.ico && copy dist\\laundry-app.exe release\\laundry-app.exe",
    "build:css": "tailwindcss -i assets/input.css -o assets/tailwind.css --minify",
    "watch:css": "tailwindcss -i assets/input.css -o assets/tailwind.css --watch",
    "ssl:setup": "node scripts/generate-ssl.js",
    "build:installer": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& 'C:\\Program Files (x86)\\Inno Setup 6\\iscc.exe' installer\\laundry.iss\""
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "langbly": "^0.3.0",
    "mysql2": "^3.6.0",
    "node-cron": "^3.0.3",
    "node-forge": "^1.4.0",
    "nodemailer": "^6.10.0",
    "pino": "^10.3.1",
    "puppeteer-core": "^24.2.0",
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0",
    "systeminformation": "^5.31.7",
    "xlsx": "^0.18.5"
  },
  "github": {
    "owner": "alaaelmorsy",
    "repo": "Laundry"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "pkg": "^5.8.1",
    "tailwindcss": "^4.2.2"
  }
}
